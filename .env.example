# ElecMaster API 키 설정 (환경 변수 템플릿)
# 실제 키는 .env 파일에 저장하고 git에 커밋하지 마세요

# OpenRouter API 키 (AI 튜터 필수)
# https://openrouter.ai에서 발급받으세요
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Finnhub API 키 (금융 정보 선택사항)
# https://finnhub.io에서 발급받으세요
FINNHUB_API_KEY=your_finnhub_api_key_here

# ExchangeRate API 키 (환율 정보 선택사항)
# https://exchangerate-api.com에서 발급받으세요
EXCHANGERATE_API_KEY=your_exchangerate_api_key_here
